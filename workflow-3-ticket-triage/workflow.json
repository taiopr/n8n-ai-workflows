          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const raw = item.json.output[0].content[0].text || '';\n  const category = raw.trim().toLowerCase().replace(/[^a-z]/g, '');\n  const validCategories = ['billing', 'technical', 'general'];\n  const finalCategory = validCategories.includes(category) ? category : 'general';\n\n  // Explicitly pull form fields from the Form Trigger node\n  const formData = $('On form submission').first().json;\n\n  return {\n    json: {\n      category: finalCategory,\n      raw_classification: raw,\n      'Full Name': formData['Full Name'],\n      'Email': formData['Email'],\n      'Describe your issue': formData['Describe your issue']\n    }\n  };\n});"
      },
