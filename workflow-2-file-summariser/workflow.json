    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  if (item.json.error) {\n    return {\n      json: {\n        file_content: `ERROR: LLM call failed.\\nReason: ${item.json.error.message}\\nTimestamp: ${new Date().toISOString()}`,\n        output_filename: `error_${Date.now()}.txt`\n      }\n    };\n  }\n\n  const summary = item.json.output[0].content[0].text || '';\n  const timestamp = new Date().toISOString();\n  const outputFilename = `summary_${Date.now()}.txt`;\n\n  const fileContent = `SUMMARY\nGenerated: ${timestamp}\n\n${summary}\n`;\n\n  return {\n    json: {\n      file_content: fileContent,\n      output_filename: outputFilename\n    }\n  };\n});"
      },
